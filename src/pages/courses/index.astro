---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
 
const courses = await getCollection('courses', ({ data }) => !data.draft);
courses.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
--- 

<BaseLayout title="Cours">
<main class="page"> 
    <h1>Cours</h1>
    <ul class="content-list"> 
        {courses.map(course => (
        <li>
            <a href={`/courses/${course.id}`}>
                <span class="content-title">{course.data.title}</span>
                <span class="content-desc">{course.data.description}</span>
                <span class="content-meta">{course.data.level} · {course.data.duration} 
                min</span>
            </a>
        </li> 
        ))}
    </ul> 
</main>
</BaseLayout> 
