---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/layout/ContentCard.astro";
import { COLLECTIONS } from "../../lib/collections";

const courses = await getCollection("courses", ({ data }) => !data.draft);
courses.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout title="Cours" description="Tous les supports de cours disponibles.">
  <main class="page">
    <h1>Cours</h1>
    <ul class="content-list" id="content-list">
      {
        courses.map((course, index) => (
          <ContentCard
            href={`${COLLECTIONS.courses.href}/${course.id}`}
            title={course.data.title}
            description={course.data.description}
            meta={`${course.data.level} · ${course.data.duration} min`}
            tags={course.data.tags}
            index={index}
          />
        ))
      }
    </ul>
    <div class="pagination" id="pagination">
      <button
        class="pagination-btn"
        id="prev-page"
        aria-label="Page précédente">← Précédent</button
      >
      <span class="page-indicator" id="page-indicator"></span>
      <button
        class="pagination-btn"
        id="next-page"
        aria-label="Page suivante">Suivant →</button
      >
    </div>
  </main>
</BaseLayout>

<script>
  import { setupPagination } from "../../lib/pagination";
  setupPagination("content-list");
</script>
