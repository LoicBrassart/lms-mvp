---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { COLLECTIONS, getMeta } from "../../lib/collections";

export async function getStaticPaths() {
  const [courses, quests, livecodings] = await Promise.all([
    getCollection("courses", ({ data }) => !data.draft),
    getCollection("quests", ({ data }) => !data.draft),
    getCollection("livecodings", ({ data }) => !data.draft),
  ]);

  const allEntries = [
    ...courses.map((e) => ({ ...e, collection: "courses" as const })),
    ...quests.map((e) => ({ ...e, collection: "quests" as const })),
    ...livecodings.map((e) => ({ ...e, collection: "livecodings" as const })),
  ];

  const allTags = [...new Set(allEntries.flatMap((e) => e.data.tags))];

  return allTags.map((tag) => ({
    params: { tag },
    props: { entries: allEntries.filter((e) => e.data.tags.includes(tag)) },
  }));
}

const { tag } = Astro.params;
const { entries } = Astro.props;

---

<BaseLayout title={`Tag : ${tag}`}>
  <main class="page">
    <p class="tag-page-back"><a href="/tags">← Tous les tags</a></p>
    <h1><span class="tag-page-label">Tag :</span> {tag}</h1>
    <ul class="content-list" id="content-list">
      {
        entries.map((entry, index) => (
          <li data-index={index}>
            <div class="content-card">
              <a
                class="content-link"
                href={`${COLLECTIONS[entry.collection].href}/${entry.id}`}
              >
                <span class="content-title">{entry.data.title}</span>
              </a>
              <span class="content-desc">{entry.data.description}</span>
              <span class="content-meta">{getMeta(entry)}</span>
              {entry.data.tags.length > 0 && (
                <ul class="tags item-tags">
                  {entry.data.tags.map((t) => (
                    <li class="tag">
                      <a href={`/tags/${t}`}>{t}</a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))
      }
    </ul>
    <div class="pagination" id="pagination">
      <button
        class="pagination-btn"
        id="prev-page"
        aria-label="Page précédente">← Précédent</button
      >
      <span class="page-indicator" id="page-indicator"></span>
      <button
        class="pagination-btn"
        id="next-page"
        aria-label="Page suivante">Suivant →</button
      >
    </div>
  </main>
</BaseLayout>

<script>
  import { setupPagination } from "../../lib/pagination";
  setupPagination("content-list");
</script>
