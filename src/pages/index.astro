---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Supports">
  <main class="home">
    <h1>Supports</h1>
    <p class="subtitle">Quêtes, supports de cours et plans de livecoding.</p>
    <nav class="home-nav">
      <a href="/courses">Cours</a>
      <a href="/quests">Quêtes</a>
      <a href="/livecodings">Livecoding</a>
    </nav>
  </main>
</BaseLayout>
<style>
  .home {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem 1rem;
  }

  .home h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .subtitle {
    color: var(--color-text-muted);
    font-size: 1.25rem;
    margin-bottom: 3rem;
  }

  .home-nav {
    display: flex;
    gap: 1rem;
  }

  .home-nav a {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.75rem 1.5rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .home-nav a:hover {
    border-color: var(--color-accent);
  }
</style>
