---
import { getCollection, render } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { COLLECTIONS } from "../../lib/collections";

export async function getStaticPaths() {
  const livecodings = await getCollection("livecodings", ({ data }) => !data.draft);
  return livecodings.map((livecoding) => ({
    params: { id: livecoding.id },
    props: { livecoding },
  }));
}

const { livecoding } = Astro.props;
const { Content } = await render(livecoding);
---

<ContentLayout
  title={livecoding.data.title}
  description={livecoding.data.description}
  tags={livecoding.data.tags}
  draft={livecoding.data.draft}
  collection={COLLECTIONS.livecodings.label}
  collectionHref={COLLECTIONS.livecodings.href}
  meta={[{ label: "Durée", value: `${livecoding.data.duration} min` }]}
  objectives={livecoding.data.objectives}
>
  <Content />
</ContentLayout>
