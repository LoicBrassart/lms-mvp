---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/layout/ContentCard.astro";
import { COLLECTIONS } from "../../lib/collections";

const quests = await getCollection("quests", ({ data }) => !data.draft);
quests.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout title="Quêtes" description="Quêtes de programmation pour pratiquer.">
  <main class="page">
    <h1>Quêtes</h1>
    <ul class="content-list" id="content-list">
      {
        quests.map((quest, index) => (
          <ContentCard
            href={`${COLLECTIONS.quests.href}/${quest.id}`}
            title={quest.data.title}
            description={quest.data.description}
            meta={quest.data.difficulty}
            tags={quest.data.tags}
            index={index}
          />
        ))
      }
    </ul>
    <div class="pagination" id="pagination">
      <button
        class="pagination-btn"
        id="prev-page"
        aria-label="Page précédente">← Précédent</button
      >
      <span class="page-indicator" id="page-indicator"></span>
      <button
        class="pagination-btn"
        id="next-page"
        aria-label="Page suivante">Suivant →</button
      >
    </div>
  </main>
</BaseLayout>

<script>
  import { setupPagination } from "../../lib/pagination";
  setupPagination("content-list");
</script>
