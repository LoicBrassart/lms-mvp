---
import BaseLayout from "../layouts/BaseLayout.astro";
import { COLLECTIONS } from "../lib/collections";
---

<BaseLayout title="Recherche">
  <main class="page">
    <h1>Recherche</h1>

    <div class="search-box">
      <input
        id="search-input"
        type="search"
        placeholder="Rechercher dans les contenus…"
        autocomplete="off"
      />
    </div>

    <div class="search-filters">
      <div class="filter-group">
        <span class="filter-label">Collection</span>
        <div class="filter-options" id="filter-collection" role="radiogroup" aria-label="Filtrer par collection">
          <button class="filter-btn active" data-value="" role="radio" aria-checked="true" tabindex="0">Tout</button>
          <button class="filter-btn" data-value={COLLECTIONS.courses.label} role="radio" aria-checked="false" tabindex="-1">{COLLECTIONS.courses.label}</button>
          <button class="filter-btn" data-value={COLLECTIONS.quests.label} role="radio" aria-checked="false" tabindex="-1">{COLLECTIONS.quests.label}</button>
          <button class="filter-btn" data-value={COLLECTIONS.livecodings.label} role="radio" aria-checked="false" tabindex="-1">{COLLECTIONS.livecodings.label}</button>
        </div>
      </div>

      <div class="filter-group">
        <span class="filter-label">Tag</span>
        <div class="filter-options" id="filter-tag" role="radiogroup" aria-label="Filtrer par tag">
          <button class="filter-btn active" data-value="" role="radio" aria-checked="true" tabindex="0">Tout</button>
        </div>
      </div>
    </div>

    <p id="search-status" class="search-status"></p>
    <ul id="search-results" class="content-list"></ul>
    <div class="pagination" id="pagination" hidden>
      <button class="pagination-btn" id="prev-page" aria-label="Page précédente">← Précédent</button>
      <span class="page-indicator" id="page-indicator"></span>
      <button class="pagination-btn" id="next-page" aria-label="Page suivante">Suivant →</button>
    </div>
  </main>
</BaseLayout>

<style>
  .search-box {
    margin-bottom: 1.5rem;
  }

  #search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    transition: border-color var(--transition-duration);
  }

  #search-input:focus {
    border-color: var(--color-accent);
  }

  .search-status {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    min-height: 1.2em;
  }

  .search-status.pagefind-error {
    background-color: #431407;
    border: 1px solid #9a3412;
    border-radius: var(--radius);
    color: #fdba74;
    padding: 0.6rem 1rem;
  }
</style>

<script>
  import { PAGE_SIZE, getPaginationElements, updatePaginationControls } from "../lib/pagination";

  interface PagefindResultData {
    url: string;
    meta: { title: string };
    excerpt: string;
  }
  interface PagefindResult {
    data: () => Promise<PagefindResultData>;
  }
  interface Pagefind {
    init: () => Promise<void>;
    filters: () => Promise<{ tag?: Record<string, number>; collection?: Record<string, number> }>;
    search: (query: string, options?: Record<string, unknown>) => Promise<{ results: PagefindResult[] }>;
  }

  const DEBOUNCE_DELAY = 200;

  let pagefind: Pagefind | undefined;
  let activeCollection = "";
  let activeTag = "";
  let cachedData: PagefindResultData[] = [];
  let currentPage = 0;

  const input = document.getElementById("search-input") as HTMLInputElement;
  const resultsList = document.getElementById("search-results") as HTMLUListElement;
  const status = document.getElementById("search-status") as HTMLParagraphElement;
  const filterTag = document.getElementById("filter-tag") as HTMLDivElement;
  const paginationEls = getPaginationElements();

  async function loadPagefind() {
    if (pagefind) return pagefind;
    try {
      pagefind = await import(/* @vite-ignore */ "/pagefind/pagefind.js");
      await pagefind.init();
      await populateTags();
    } catch {
      status.textContent = "La recherche n'est disponible qu'après un build (npm run build).";
      status.classList.add("pagefind-error");
    }
    return pagefind;
  }

  async function populateTags() {
    const filters = await pagefind!.filters();
    const tags: string[] = Object.keys(filters.tag ?? {}).sort();

    tags.forEach((tag) => {
      const btn = document.createElement("button");
      btn.className = "filter-btn";
      btn.dataset.value = tag;
      btn.textContent = tag;
      btn.setAttribute("role", "radio");
      btn.setAttribute("aria-checked", "false");
      btn.setAttribute("tabindex", "-1");
      btn.addEventListener("click", () => setFilter("tag", tag, btn));
      filterTag.appendChild(btn);
    });
  }

  function setFilter(type: "collection" | "tag", value: string, btn: HTMLButtonElement) {
    const groupId = type === "collection" ? "filter-collection" : "filter-tag";
    document.querySelectorAll<HTMLButtonElement>(`#${groupId} [role="radio"]`).forEach((b) => {
      b.classList.remove("active");
      b.setAttribute("aria-checked", "false");
      b.setAttribute("tabindex", "-1");
    });
    btn.classList.add("active");
    btn.setAttribute("aria-checked", "true");
    btn.setAttribute("tabindex", "0");

    if (type === "collection") activeCollection = value;
    else activeTag = value;

    search(input.value);
  }

  function setupRadioGroupKeyboard(groupId: string) {
    const group = document.getElementById(groupId);
    if (!group) return;
    group.addEventListener("keydown", (e: KeyboardEvent) => {
      const radios = Array.from(group.querySelectorAll<HTMLButtonElement>('[role="radio"]'));
      const current = radios.findIndex((r) => r === document.activeElement);
      if (current === -1) return;
      let next = current;
      if (e.key === "ArrowRight" || e.key === "ArrowDown") {
        e.preventDefault();
        next = (current + 1) % radios.length;
      } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
        e.preventDefault();
        next = (current - 1 + radios.length) % radios.length;
      }
      if (next !== current) {
        radios[next].focus();
        radios[next].click();
      }
    });
  }

  function buildResultCard(url: string, title: string, excerpt: string): HTMLLIElement {
    const li = document.createElement("li");
    const card = document.createElement("div");
    card.className = "content-card";

    const link = document.createElement("a");
    link.className = "content-link";
    link.href = url;
    const titleSpan = document.createElement("span");
    titleSpan.className = "content-title";
    titleSpan.textContent = title;
    link.appendChild(titleSpan);

    const desc = document.createElement("span");
    desc.className = "content-desc";
    desc.textContent = excerpt;

    card.appendChild(link);
    card.appendChild(desc);
    li.appendChild(card);
    return li;
  }

  function renderPage(page: number) {
    resultsList.innerHTML = "";
    const totalPages = Math.ceil(cachedData.length / PAGE_SIZE);
    const pageData = cachedData.slice(page * PAGE_SIZE, (page + 1) * PAGE_SIZE);

    for (const data of pageData) {
      resultsList.appendChild(buildResultCard(data.url, data.meta.title ?? "Sans titre", data.excerpt));
    }

    if (paginationEls) updatePaginationControls(page, totalPages, paginationEls);
  }

  async function search(query: string) {
    const pf = await loadPagefind();
    if (!pf) return;

    const filters: Record<string, string> = {};
    if (activeCollection) filters.collection = activeCollection;
    if (activeTag) filters.tag = activeTag;

    const response = await pf.search(query || "", { filters });
    status.textContent = response
      ? `${response.results.length} résultat${response.results.length !== 1 ? "s" : ""}`
      : "";

    if (!response) return;

    cachedData = await Promise.all(response.results.map((r) => r.data()));
    currentPage = 0;
    renderPage(0);
  }

  if (paginationEls) {
    paginationEls.prevBtn.addEventListener("click", () => {
      currentPage--;
      renderPage(currentPage);
    });
    paginationEls.nextBtn.addEventListener("click", () => {
      currentPage++;
      renderPage(currentPage);
    });
  }

  document.querySelectorAll("#filter-collection [role='radio']").forEach((btn) => {
    btn.addEventListener("click", () =>
      setFilter("collection", (btn as HTMLButtonElement).dataset.value ?? "", btn as HTMLButtonElement),
    );
  });

  document.querySelectorAll("#filter-tag [role='radio']").forEach((btn) => {
    btn.addEventListener("click", () =>
      setFilter("tag", (btn as HTMLButtonElement).dataset.value ?? "", btn as HTMLButtonElement),
    );
  });

  setupRadioGroupKeyboard("filter-collection");
  setupRadioGroupKeyboard("filter-tag");

  let debounceTimer: ReturnType<typeof setTimeout>;
  input.addEventListener("input", (e) => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(
      () => search((e.target as HTMLInputElement).value),
      DEBOUNCE_DELAY,
    );
  });
  loadPagefind();
</script>
